            "definition": "{\"Comment\":\"KR Data Pipeline - E2E orchestration (Transform → Image → Load → Vector)\",\"StartAt\":\"CheckSkipTransform\",\"States\":{\"AggregateReviewManifest\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"HandleFailure\",\"ResultPath\":\"$.error_info\"}],\"Next\":\"LoadStage\",\"Parameters\":{\"bucket.$\":\"$.bucket\",\"command\":\"aggregate_review\",\"image_results.$\":\"$.image_results\",\"ingest_date.$\":\"$.ingest_date\"},\"Resource\":\"arn:aws:lambda:us-east-1:925273580929:function:kr-pipeline-image\",\"ResultPath\":\"$.review_manifest\",\"Type\":\"Task\"},\"BuildCityList\":{\"Comment\":\"Constructs city_list from S3 processed/{date}/passed/ file listing\",\"Next\":\"ImageStage\",\"Type\":\"Pass\"},\"CheckSkipTransform\":{\"Choices\":[{\"BooleanEquals\":true,\"Next\":\"BuildCityList\",\"Variable\":\"$.skip_transform\"}],\"Default\":\"TransformStage\",\"Type\":\"Choice\"},\"GenerateReport\":{\"Next\":\"Success\",\"Parameters\":{\"bucket.$\":\"$.bucket\",\"command\":\"generate_report\",\"execution_context.$\":\"$\",\"ingest_date.$\":\"$.ingest_date\"},\"Resource\":\"arn:aws:lambda:us-east-1:925273580929:function:kr-pipeline-image\",\"ResultPath\":\"$.report\",\"Type\":\"Task\"},\"HandleFailure\":{\"Next\":\"GenerateReport\",\"ResultPath\":\"$.failure_info\",\"Type\":\"Pass\"},\"ImageStage\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"HandleFailure\",\"ResultPath\":\"$.error_info\"}],\"ItemsPath\":\"$.city_list\",\"Iterator\":{\"StartAt\":\"InvokeImageProcessor\",\"States\":{\"InvokeImageProcessor\":{\"End\":true,\"Resource\":\"arn:aws:lambda:us-east-1:925273580929:function:kr-pipeline-image\",\"Retry\":[{\"BackoffRate\":2,\"ErrorEquals\":[\"States.TaskFailed\",\"Lambda.ServiceException\",\"Lambda.SdkClientException\"],\"IntervalSeconds\":5,\"MaxAttempts\":1}],\"Type\":\"Task\"}}},\"MaxConcurrency\":10,\"Next\":\"AggregateReviewManifest\",\"ResultPath\":\"$.image_results\",\"Type\":\"Map\"},\"LoadStage\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"HandleFailure\",\"ResultPath\":\"$.error_info\"}],\"Next\":\"VectorStage\",\"Parameters\":{\"bucket.$\":\"$.bucket\",\"command\":\"load\",\"ingest_date.$\":\"$.ingest_date\",\"table_name.$\":\"$.table_name\"},\"Resource\":\"arn:aws:lambda:us-east-1:925273580929:function:kr-pipeline-loader\",\"ResultPath\":\"$.load_results\",\"Retry\":[{\"BackoffRate\":2,\"ErrorEquals\":[\"States.TaskFailed\",\"Lambda.ServiceException\",\"Lambda.SdkClientException\"],\"IntervalSeconds\":5,\"MaxAttempts\":2}],\"Type\":\"Task\"},\"Success\":{\"Type\":\"Succeed\"},\"TransformStage\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"HandleFailure\",\"ResultPath\":\"$.error_info\"}],\"ItemsPath\":\"$.city_files\",\"Iterator\":{\"StartAt\":\"InvokeTransform\",\"States\":{\"InvokeTransform\":{\"End\":true,\"Resource\":\"arn:aws:lambda:us-east-1:925273580929:function:kr-pipeline-transform\",\"Retry\":[{\"BackoffRate\":2,\"ErrorEquals\":[\"States.TaskFailed\",\"Lambda.ServiceException\",\"Lambda.SdkClientException\"],\"IntervalSeconds\":3,\"MaxAttempts\":2}],\"Type\":\"Task\"}}},\"MaxConcurrency\":10,\"Next\":\"BuildCityList\",\"ResultPath\":\"$.transform_results\",\"Type\":\"Map\"},\"VectorStage\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"GenerateReport\",\"ResultPath\":\"$.vector_error\"}],\"Next\":\"GenerateReport\",\"Parameters\":{\"command\":\"vector-build\",\"rebuild_mode\":\"full\",\"table_name.$\":\"$.table_name\"},\"Resource\":\"arn:aws:lambda:us-east-1:925273580929:function:kr-pipeline-loader\",\"ResultPath\":\"$.vector_results\",\"Retry\":[{\"BackoffRate\":2,\"ErrorEquals\":[\"States.TaskFailed\",\"Lambda.ServiceException\",\"Lambda.SdkClientException\"],\"IntervalSeconds\":5,\"MaxAttempts\":1}],\"Type\":\"Task\"}}}",
