aws_profile  = "skn26_final"
aws_region   = "us-east-1"
env          = "dev"
bucket_base_name = "lovv-data-pipeline"
domain_dynamodb_table_name = "TourKoreaDomainData"
domain_dynamodb_table_name_v2 = "TourKoreaDomainDataV2"
vector_bucket_name = "lovv-vector-dev"
kr_vector_index_name = "kr-tour-domain-v2"
kr_vector_index_data_type = "float32"
kr_vector_index_dimension = 1024
kr_vector_index_distance_metric = "cosine"
kr_vector_index_non_filterable_metadata_keys = ["raw_s3_uri", "ddb_pk", "ddb_sk", "embedding_model"]
kr_vector_batch_size = 250
kr_vector_map_max_concurrency = 5
agentcore_v1_vector_bucket_name = "lovv-agentcore-v1-vector"
agentcore_v1_vector_index_name = "kr-agentcore-v1"
